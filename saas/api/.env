# ── MySQL connection ───────────────────────────
# Use a dedicated low-privilege DB user, NOT root, in production
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=insijam

# ── Server ─────────────────────────────────────
PORT=3001
NODE_ENV=production   # change to "production" when deploying

# ── Admin panel secret key ─────────────────────
# REQUIRED. Must be 32+ random characters. The server will refuse to
# start if this is missing or set to a known weak value.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=a3f9c2e1b8d4f7a0e5c3b2d1f8a4e7b0c9d3f2a1e6b5c8d4f1a7e3b0c2d9f5a8

# ── CORS (comma-separated origins) ─────────────
# In production, set this to your actual domain(s).
# In development, localhost origins are allowed automatically.
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
